# ===========================================
# Formlabs 원격제어 시스템 - 환경 설정
# ===========================================
# 이 파일을 .env로 복사한 후 실제 값으로 수정하세요
# cp .env.example .env

# ===========================================
# 앱 설정
# ===========================================
APP_NAME=Formlabs 원격제어 시스템
APP_VERSION=1.0.0
DEBUG=true

# ===========================================
# Formlabs API 인증
# ===========================================
# Dashboard > Developer Tools에서 발급
# https://dashboard.formlabs.com/developer-tools/
FORMLABS_CLIENT_ID=your_client_id_here
FORMLABS_CLIENT_SECRET=your_client_secret_here
FORMLABS_API_BASE_URL=https://api.formlabs.com

# 토큰 만료 1시간 전 자동 갱신
TOKEN_REFRESH_MARGIN_SECONDS=3600

# ===========================================
# 폴링 설정
# ===========================================
# Rate Limit: IP당 100 req/sec, 사용자당 1500 req/hr
# 권장: 10초 이상
POLLING_INTERVAL_SECONDS=15

# ===========================================
# 프린터 설정
# ===========================================
# Form 4 프린터 4대 시리얼 번호 (쉼표로 구분)
# Dashboard 또는 프린터 설정에서 확인 가능
PRINTER_SERIALS=["SERIAL1","SERIAL2","SERIAL3","SERIAL4"]

# ===========================================
# 데이터베이스 (Phase 2에서 사용)
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/formlabs_db

# ===========================================
# 이메일 알림 설정
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFICATION_EMAIL_TO=["admin@company.com","manager@company.com"]

# ===========================================
# 슬랙 알림 설정
# ===========================================
# Slack Webhook URL (Incoming Webhook 앱에서 생성)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX

# ===========================================
# FCM 푸시 알림 설정
# ===========================================
# Firebase Console > Project Settings > Cloud Messaging
FCM_SERVER_KEY=your_fcm_server_key_here

# ===========================================
# 알림 조건
# ===========================================
NOTIFY_ON_PRINT_COMPLETE=true
NOTIFY_ON_PRINT_ERROR=true
NOTIFY_ON_LOW_RESIN=true
LOW_RESIN_THRESHOLD_ML=100

# Local API 환경 설정

# 앱 설정
APP_NAME=Formlabs Local API
APP_VERSION=0.1.0
DEBUG=true

# PreFormServer 설정
# Windows PC에서 PreFormServer가 실행 중인 IP 주소
PREFORM_SERVER_HOST=localhost
PREFORM_SERVER_PORT=44388
PREFORM_SERVER_TIMEOUT=60

# 파일 업로드 설정
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100

# 데이터베이스 (SQLite)
DATABASE_URL=sqlite:///./presets.db

# Form 4 기본 설정
DEFAULT_MACHINE_TYPE=FORM-4-0
DEFAULT_LAYER_THICKNESS_MM=0.05
